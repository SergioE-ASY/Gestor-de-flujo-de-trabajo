# ── Core ──────────────────────────────────────────────────────────────────────
# Generate a strong key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-cambia-esto-en-produccion-genera-una-clave-segura
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_LOG_LEVEL=WARNING

# ── Database ───────────────────────────────────────────────────────────────────
DB_NAME=taskmanager
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ── Redis (required in production for effective rate limiting) ─────────────────
# REDIS_URL=redis://localhost:6379/0

# ── HTTPS / Cookie security (set to True in production behind HTTPS) ───────────
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
# HSTS: once set, browsers enforce HTTPS for HSTS_SECONDS. Start with a low value.
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# ── Google Gemini AI (requerido para funciones IA premium) ─────────────────────
# Obtén tu key en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
