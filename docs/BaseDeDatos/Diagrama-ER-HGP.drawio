        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;erDiagram\n    ORGANIZATION {\n        UUID id PK\n        VARCHAR name\n        VARCHAR crm_company_id\n        VARCHAR logo_url\n        TIMESTAMPTZ created_at\n        TIMESTAMPTZ updated_at\n        TIMESTAMPTZ deleted_at\n    }\n\n    USER {\n        UUID id PK\n        UUID organization_id FK\n        VARCHAR name\n        VARCHAR email\n        VARCHAR password_hash\n        ENUM role\n        VARCHAR avatar_url\n        BOOLEAN is_active\n        TIMESTAMPTZ last_login_at\n    }\n\n    PROJECT {\n        UUID id PK\n        UUID organization_id FK\n        UUID owner_id FK\n        VARCHAR key\n        VARCHAR name\n        TEXT description\n        ENUM status\n        ENUM priority\n        DATE start_date\n        DATE due_date\n    }\n\n    PROJECT_MEMBER {\n        UUID id PK\n        UUID project_id FK\n        UUID user_id FK\n        ENUM role\n        TIMESTAMPTZ joined_at\n    }\n\n    SPRINT {\n        UUID id PK\n        UUID project_id FK\n        VARCHAR name\n        TEXT goal\n        ENUM status\n        TIMESTAMPTZ start_date\n        TIMESTAMPTZ end_date\n    }\n\n    TASK {\n        UUID id PK\n        UUID project_id FK\n        UUID sprint_id FK\n        UUID assignee_id FK\n        UUID parent_task_id FK\n        INTEGER project_sequence\n        ENUM type\n        VARCHAR title\n        TEXT description\n        ENUM status\n        ENUM priority\n        INTEGER position\n        INTEGER estimated_min\n        DATE due_date\n        TIMESTAMPTZ completed_at\n    }\n\n    TAG {\n        UUID id PK\n        UUID project_id FK\n        VARCHAR name\n        VARCHAR color\n    }\n\n    TASK_TAG {\n        UUID task_id PK, FK\n        UUID tag_id PK, FK\n    }\n\n    COMMENT {\n        UUID id PK\n        UUID task_id FK\n        UUID user_id FK\n        TEXT content\n        TIMESTAMPTZ created_at\n    }\n\n    ATTACHMENT {\n        UUID id PK\n        UUID task_id FK\n        UUID uploaded_by FK\n        VARCHAR filename\n        VARCHAR file_url\n        INTEGER file_size\n        VARCHAR mime_type\n    }\n\n    TIME_LOG {\n        UUID id PK\n        UUID task_id FK\n        UUID user_id FK\n        INTEGER minutes\n        TEXT note\n        DATE logged_date\n    }\n\n    NOTIFICATION {\n        UUID id PK\n        UUID user_id FK\n        UUID task_id FK\n        UUID project_id FK\n        ENUM type\n        TEXT message\n        BOOLEAN is_read\n    }\n\n    %% Relaciones (Cardinalidad)\n    ORGANIZATION ||--o{ USER : \&quot;tiene\&quot;\n    ORGANIZATION ||--o{ PROJECT : \&quot;posee\&quot;\n    \n    USER ||--o{ PROJECT : \&quot;es dueño de (owner)\&quot;\n    USER ||--o{ PROJECT_MEMBER : \&quot;participa como\&quot;\n    USER ||--o{ TASK : \&quot;se le asigna\&quot;\n    USER ||--o{ COMMENT : \&quot;escribe\&quot;\n    USER ||--o{ ATTACHMENT : \&quot;sube\&quot;\n    USER ||--o{ TIME_LOG : \&quot;registra tiempo\&quot;\n    USER ||--o{ NOTIFICATION : \&quot;recibe\&quot;\n\n    PROJECT ||--o{ PROJECT_MEMBER : \&quot;tiene miembros\&quot;\n    PROJECT ||--o{ SPRINT : \&quot;contiene\&quot;\n    PROJECT ||--o{ TASK : \&quot;contiene\&quot;\n    PROJECT ||--o{ TAG : \&quot;define\&quot;\n    PROJECT ||--o{ NOTIFICATION : \&quot;genera alertas\&quot;\n\n    SPRINT ||--o{ TASK : \&quot;agrupa\&quot;\n\n    TASK ||--o{ TASK : \&quot;tiene subtareas (parent)\&quot;\n    TASK ||--o{ TASK_TAG : \&quot;tiene\&quot;\n    TASK ||--o{ COMMENT : \&quot;tiene\&quot;\n    TASK ||--o{ ATTACHMENT : \&quot;tiene\&quot;\n    TASK ||--o{ TIME_LOG : \&quot;acumula\&quot;\n    TASK ||--o{ NOTIFICATION : \&quot;genera alertas\&quot;\n\n    TAG ||--o{ TASK_TAG : \&quot;aplica a\&quot;&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="5_omdoXL_7aJyvf11Td4-1">
